{
  "name": "@cyberlisans/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts",
    "./vercel-entry": "./src/vercel-entry.ts"
  },
  "scripts": {
    "dev": "node --env-file=.env --import ./src/instrument.ts --import tsx --watch src/index.ts",
    "build": "tsc",
    "build:vercel": "tsc src/vercel-entry.ts --outDir .vercel-build --module commonjs --target es2022 --esModuleInterop --skipLibCheck",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo .vercel-build"
  },
  "dependencies": {
    "@cyberlisans/auth": "workspace:*",
    "@cyberlisans/db": "workspace:*",
    "@cyberlisans/payments": "workspace:*",
    "@cyberlisans/validators": "workspace:*",
    "@hono/node-server": "1.13.7",
    "@hono/zod-validator": "0.4.2",
    "@sentry/node": "^10.63.0",
    "@supabase/supabase-js": "2.47.10",
    "hono": "4.7.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.10",
    "eslint": "9.17.0",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
