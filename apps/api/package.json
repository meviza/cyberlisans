{
  "name": "@cyberlisans/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@cyberlisans/auth": "workspace:*",
    "@cyberlisans/db": "workspace:*",
    "@cyberlisans/payments": "workspace:*",
    "@cyberlisans/validators": "workspace:*",
    "@hono/node-server": "1.13.7",
    "@hono/zod-validator": "0.4.2",
    "hono": "4.7.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.10",
    "eslint": "9.17.0",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
