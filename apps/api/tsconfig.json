{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@cyberlisans/db": ["../../packages/db/src"],
      "@cyberlisans/auth": ["../../packages/auth/src"],
      "@cyberlisans/validators": ["../../packages/validators/src"],
      "@cyberlisans/payments": ["../../packages/payments/src"],
      "@cyberlisans/types": ["../../packages/types/src"]
    },
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "../../packages"]
}
